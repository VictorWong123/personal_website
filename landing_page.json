{
    "sourceImage": "Screenshot 2026-01-22 at 10.51.27 PM.pdf (page 1)",
    "designName": "Dark Landing + 2x2 Nav Cards",
    "theme": {
        "colors": {
            "bg": "#141414",
            "panel": "#1B1B1B",
            "panelBorder": "#3A3A3A",
            "textPrimary": "#F2F2F2",
            "textSecondary": "#B9B9B9",
            "muted": "#8A8A8A",
            "accent": "#D9C26A",
            "accentHover": "#CBB75F",
            "shadow": "rgba(0,0,0,0.35)"
        },
        "typography": {
            "fontFamily": "ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial",
            "heroHelloSize": "text-sm md:text-base",
            "heroNameSize": "text-3xl md:text-5xl",
            "bodySize": "text-sm md:text-base",
            "cardLabelSize": "text-sm md:text-base",
            "fontWeights": {
                "hello": 600,
                "name": 800,
                "body": 400,
                "cardLabel": 500,
                "button": 600
            }
        },
        "radius": {
            "card": "rounded-2xl",
            "button": "rounded-md"
        }
    },
    "layout": {
        "containerMaxWidth": "max-w-[1800px]",
        "grid": "grid-cols-1 lg:grid-cols-[1.3fr_1fr]",
        "gap": "gap-16 lg:gap-20",
        "verticalAlign": "items-center",
        "heroLeftWidth": "lg:pr-10",
        "cardsRight": {
            "grid": "grid-cols-1 sm:grid-cols-2",
            "gap": "gap-10"
        }
    },
    "content": {
        "hero": {
            "hello": "Hello 👋",
            "nameLine": "I’m Victor Wong",
            "description": "I build data-driven, accessible digital experiences for the web and beyond.",
            "primaryCta": {
                "label": "Download Resume",
                "href": "/personal_website/Victor_wong_resume (7).pdf"
            }
        },
        "navCards": [
            {
                "id": "projects",
                "label": "My Projects",
                "href": "/projects",
                "icon": "folder-heart"
            },
            {
                "id": "about",
                "label": "About me",
                "href": "/about",
                "icon": "user-hex"
            },
            {
                "id": "Experience",
                "label": "My Experience",
                "href": "/Experience",
                "icon": "edit"
            },
            {
                "id": "contact",
                "label": "Contact me",
                "href": "/contact",
                "icon": "mail"
            }
        ]
    },
    "components": {
        "Hero": {
            "elements": [
                "helloTag",
                "nameHeadline",
                "descriptionParagraph",
                "primaryButton"
            ]
        },
        "NavCard": {
            "elements": [
                "iconBox",
                "label"
            ],
            "states": {
                "default": "border + subtle panel",
                "hover": "border brighter + slight lift + glow"
            }
        }
    },
    "stylingNotes": {
        "background": "Near-black full-page background.",
        "cards": "Dark panels with visible border, generous padding, centered icon and label.",
        "icons": "Thin line icons, light gray/white stroke.",
        "button": "Warm yellow filled button on left hero.",
        "overallMood": "Minimal, modern, high-contrast, lots of breathing room."
    }
}